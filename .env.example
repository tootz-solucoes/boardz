# URL do Cloudflare Worker que faz proxy para a API do ClickUp (seguro expor)
# O token do ClickUp fica como secret no Worker — nunca chega ao browser
# Deploy: ver worker/wrangler.toml
VITE_CLICKUP_PROXY_URL=https://clickup-proxy.tootzcombr.workers.dev
VITE_VOICERSS_PROXY_URL=https://voicerss-proxy.tootzcombr.workers.dev